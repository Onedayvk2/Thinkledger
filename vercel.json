{
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/generate", "destination": "/api/generate.js" },
    { "source": "/api/save", "destination": "/api/save.js" },
    { "source": "/api/profile", "destination": "/api/profile.js" },
    { "source": "/profile/:id", "destination": "/profile.html" },
    { "source": "/app", "destination": "/app.html" },
    { "source": "/demo", "destination": "/demo.html" },
    { "source": "/", "destination": "/index.html" }
  ],
  "functions": {
    "api/generate.js": { "maxDuration": 60 },
    "api/save.js": { "maxDuration": 15 },
    "api/profile.js": { "maxDuration": 15 }
  }
}
